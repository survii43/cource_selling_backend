PORT=3001
SERVICE_NAME=auth
MYSQL_HOST=127.0.0.1
# Must match your MySQL (Docker default is often 3306).
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootpass
MYSQL_DATABASE=auth_db
JWT_SECRET=change-me-to-a-long-random-secret-at-least-16-chars
JWT_EXPIRES_IN=7d
# Optional: seed one admin when no admin exists (single-shop operator)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
